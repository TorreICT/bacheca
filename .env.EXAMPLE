# FastAPI server
BACHECA_DASHBOARD_HOST=0.0.0.0
BACHECA_DASHBOARD_PORT=8080
BACHECA_STATIC_ROOT=bacheca-frontend
BACHECA_MENU_TIMEOUT_MS=10000
BACHECA_TIMEZONE=Europe/Rome
BACHECA_BAR_WIDGET_STATE_PATH=.cache/bar-widget-state.json

# Telegram bar widget bot
TELEGRAM_BOT_TOKEN=123456:replace-with-your-token
TELEGRAM_SUPERADMIN_CHAT_IDS=123456789,-1001234567890
TELEGRAM_ADMINS_PATH=.cache/telegram-admins.json

# MyCollege
MYCOLLEGE_MENU_URL=https://mycollegeapp.rui.it/jsonapi
MYCOLLEGE_PASTI_URL=https://mycollegeapp.rui.it/jsonapi
MYCOLLEGE_RESIDENCE=dG9ycmVzY2FsbGE-
MYCOLLEGE_MENU_ENABLED=1
MYCOLLEGE_TURNO_SINGOLO=false

# Pizza Index
PIZZA_INDEX_URL=https://www.pizzint.watch/api/dashboard-data

# Weather
BACHECA_WEATHER_FORECAST_URL=https://api.open-meteo.com/v1/forecast
BACHECA_WEATHER_CACHE_PATH=.cache/weather-cache.json
BACHECA_WEATHER_CACHE_TTL_MS=600000

# Random photo thumbnails
BACHECA_PHOTO_ROOT=/mnt/foto
BACHECA_PHOTO_CACHE_DIR=.cache/photo-thumbs
BACHECA_PHOTO_DB_PATH=.cache/photos.sqlite
BACHECA_PHOTO_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp
BACHECA_PHOTO_THUMBNAIL_WIDTH=900
BACHECA_PHOTO_THUMBNAIL_HEIGHT=520
BACHECA_PHOTO_THUMBNAIL_QUALITY=82
BACHECA_PHOTO_SCAN_INTERVAL_MS=900000
BACHECA_PHOTO_YEARS_BACK=1
BACHECA_PHOTO_PRELOAD_BATCH=40

# Bar widget soccer provider
BACHECA_SOCCER_PROVIDER=football-data
BACHECA_SOCCER_API_TOKEN=your-football-data-token
BACHECA_SOCCER_BASE_URL=https://api.football-data.org/v4
BACHECA_SOCCER_CACHE_PATH=.cache/soccer-cache.json
BACHECA_SOCCER_BADGE_CACHE_DIR=.cache/soccer-badges
BACHECA_SOCCER_CACHE_TTL_MS=600000
BACHECA_SOCCER_LOOKBACK_DAYS=30
BACHECA_SOCCER_LOOKAHEAD_DAYS=30
BACHECA_SOCCER_MAX_ITEMS=4

# Bar widget basketball provider
BACHECA_BASKETBALL_PROVIDER=thesportsdb
BACHECA_BASKETBALL_API_TOKEN=
BACHECA_BASKETBALL_BASE_URL=https://www.thesportsdb.com/api/v1/json
BACHECA_BASKETBALL_CACHE_PATH=.cache/basketball-cache.json
BACHECA_BASKETBALL_BADGE_CACHE_DIR=.cache/basketball-badges
BACHECA_BASKETBALL_CACHE_TTL_MS=1800000
BACHECA_BASKETBALL_LOOKBACK_DAYS=30
BACHECA_BASKETBALL_LOOKAHEAD_DAYS=30
BACHECA_BASKETBALL_MAX_ITEMS=4
BACHECA_BASKETBALL_DEFAULT_SEASON=

# Google Calendar
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PROJECT_NUMBER=your-google-project-number
GOOGLE_CALENDAR_ID=eventi.torrescalla@fondazionerui.it
GOOGLE_CALENDAR_MAX_RESULTS=50
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
